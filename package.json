{
  "name": "@open-creator-rails/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for interacting with Open Creator Rails contracts and indexer.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "test": "vitest run src/test/unit",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run src/test/integration",
    "abis:sync": "node scripts/sync-contract-abis.mjs",
    "abis:check": "node scripts/sync-contract-abis.mjs --check",
    "submodule:pull": "git submodule update --init --recursive && git submodule update --remote --merge open-creator-rails"
  },
  "dependencies": {
    "viem": "^2.51.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "typescript": "^5.3.2",
    "vitest": "^4.1.0"
  }
}
