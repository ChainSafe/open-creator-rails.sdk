{
  "name": "@chainsafe/open-creator-rails-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for interacting with Open Creator Rails contracts and indexer.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChainSafe/open-creator-rails.sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run test && pnpm run lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run src/test/unit",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest run src/test/integration",
    "abis:sync": "node scripts/sync-contract-abis.mjs",
    "abis:check": "node scripts/sync-contract-abis.mjs --check",
    "submodule:pull": "git submodule update --init --recursive && git submodule update --remote --merge open-creator-rails"
  },
  "dependencies": {
    "viem": "^2.21.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "typescript": "^5.3.2",
    "vitest": "^4.1.0"
  }
}
